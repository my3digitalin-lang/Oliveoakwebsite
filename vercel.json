{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "installCommand": "npm install",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/Frames-webp-pc/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/Frames-webp-mobile/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(webp|jpg|jpeg|png|svg|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    }
  ]
}
